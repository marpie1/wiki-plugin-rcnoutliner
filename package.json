{
  "name": "wiki-plugin-rcnoutliner",
  "version": "0.1.5",
  "description": "Federated Wiki - RCN Outliner Plug-in",
  "keywords": [
    "wiki",
    "federated wiki",
    "plugin",
    "rcn",
    "outliner"
  ],
  "author": "RCN Network <rcn@relocalizecreativity.net>",
  "license": "MIT",
  "repository": {"type": "git", "url": "https://github.com/marpie1/wiki-plugin-rcnoutliner.git"},
  "main": "index.js",
  "files": [
    "client/rcnoutliner.js",
    "client/more-outliner.html",
    "factory.json",
    "index.js",
    "pages"
  ],
  "scripts": {
    "build": "esbuild src/index.jsx --bundle --minify --jsx-factory=h --jsx-fragment=Fragment --outfile=client/rcnoutliner.js --external:jquery",
